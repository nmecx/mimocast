# MiMo API credentials — get yours at https://platform.xiaomimimo.com/
# Leave MIMOCAST_API_KEY unset to run in mock mode (no spend, canned outputs).
MIMOCAST_API_KEY=
MIMOCAST_BASE_URL=https://api.xiaomimimo.com/v1

# Model routing — MiMo V2.5 family
MIMOCAST_REASONER_MODEL=mimo-v2.5-reasoner
MIMOCAST_VISION_MODEL=mimo-v2.5-vision
MIMOCAST_TTS_MODEL=mimo-v2.5-tts

# TTS voice id (provider-specific; safe default below)
MIMOCAST_TTS_VOICE=mimo-female-warm

# Output dirs
MIMOCAST_WORK_DIR=~/.mimocast
MIMOCAST_OUT_DIR=./out

# Logging
MIMOCAST_LOG_LEVEL=INFO
